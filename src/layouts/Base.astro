---
import '../styles/global.css';
import { config } from '../data/hub.config';

interface Props {
  title: string;
  description?: string;
}

const { title, description = config.tagline } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,400&family=Inter:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen flex flex-col bg-sand-50 text-text-body antialiased">
    <header class="fixed top-0 left-0 right-0 z-50 bg-ocean-900/80 backdrop-blur-md border-b border-white/5">
      <nav class="max-w-6xl mx-auto px-6 py-3.5 flex items-center justify-between">
        <a href="/" class="font-heading text-lg text-white/90 hover:text-white transition-colors">
          {config.name}
        </a>
        <ul class="flex gap-8 text-xs font-medium tracking-widest uppercase">
          <li><a href="/water/" class="text-ocean-300 hover:text-white transition-colors">Water</a></li>
          <li><a href="/water/explore" class="text-ocean-300 hover:text-white transition-colors">Explore</a></li>
          <li><a href="/water/quiz" class="text-ocean-300 hover:text-white transition-colors">Quiz</a></li>
        </ul>
      </nav>
    </header>

    <main class="flex-1 pt-[52px]">
      <slot />
    </main>

    <footer class="bg-ocean-900 border-t border-white/5">
      <div class="max-w-6xl mx-auto px-6 py-10 text-center">
        <p class="font-heading text-sm text-ocean-300/60">&copy; {new Date().getFullYear()} {config.name}</p>
        <p class="mt-1 text-xs text-ocean-300/40 tracking-wider">{config.domains.hub}</p>
      </div>
    </footer>
  </body>
</html>
