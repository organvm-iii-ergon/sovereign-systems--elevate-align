---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import CTAButton from '../../components/CTAButton.astro';
import ComingSoon from '../../components/ComingSoon.astro';

export async function getStaticPaths() {
  const pillars = await getCollection('pillars');
  return pillars.map((pillar) => ({
    params: { slug: pillar.id.replace(/\.md$/, '') },
    props: { pillar },
  }));
}

const { pillar } = Astro.props;
const { Content } = await pillar.render();
const { title, emoji, tagline, status } = pillar.data;
---

<Base title={title}>
  <section class="relative min-h-[50vh] flex flex-col items-center justify-center text-center px-6 py-24 glow-bg overflow-hidden">
    <div class="relative text-6xl mb-6">{emoji}</div>
    <h1 class="relative font-heading text-[clamp(40px,5vw,64px)] font-light text-white leading-[1.1] mb-4" style="text-shadow: 0 0 50px rgba(17,154,158,0.12);">
      {title}
    </h1>
    <p class="relative font-heading italic text-white/40 text-[20px] leading-relaxed">
      {tagline}
    </p>
  </section>

  <div class="divider-line"></div>
  <section class="py-16 px-6 bg-ocean-900">
    <div class="max-w-[640px] mx-auto">
      {status === 'placeholder' ? (
        <ComingSoon title={title} emoji={emoji} message="This pillar is being built. The foundation comes first." />
      ) : (
        <div class="branch-content text-[16px] leading-[1.9]">
          <Content />
        </div>
      )}
    </div>
  </section>

  <section class="py-16 px-6 bg-ocean-900 text-center">
    <CTAButton href="/" label="Back to the spiral" variant="secondary" />
  </section>
</Base>
