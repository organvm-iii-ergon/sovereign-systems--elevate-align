---
import Base from '../layouts/Base.astro';
import CTAButton from '../components/CTAButton.astro';
---

<Base title="Not Found — Sovereign Systems Spiral" description="This page doesn't exist yet.">
  <section class="min-h-[60vh] flex items-center justify-center px-6 bg-ocean-900">
    <div class="max-w-md text-center">
      <p class="text-[64px] mb-6 opacity-30">🌊</p>
      <h1 class="font-heading text-[36px] font-light text-white mb-4">Off the path</h1>
      <p class="text-white/35 text-[16px] font-light leading-relaxed mb-10">
        This page doesn't exist — but the spiral does. Head back and find your starting point.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <CTAButton href="/" label="Back to the spiral" />
        <CTAButton href="/water/" label="Explore water" variant="secondary" />
      </div>
    </div>
  </section>
</Base>
