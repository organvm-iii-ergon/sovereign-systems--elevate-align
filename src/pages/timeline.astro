---
import Base from '../layouts/Base.astro';
import {
  SPIRAL_VERSIONS,
  versionsGroupedByCategory,
} from '../data/spiral-versions';

const groups = versionsGroupedByCategory();
const live = groups['production-live'];
const historical = groups['production-historical'];

const totalCount = SPIRAL_VERSIONS.length;
const playableCount = SPIRAL_VERSIONS.filter(
  (v) => v.status === 'playable' || v.status === 'live',
).length;
const pendingCount = SPIRAL_VERSIONS.filter(
  (v) => v.status === 'snapshot-pending',
).length;

function formatDate(iso: string): string {
  const d = new Date(iso + 'T00:00:00Z');
  return d.toLocaleDateString('en-US', {
    month: 'long',
    day: 'numeric',
    year: 'numeric',
    timeZone: 'UTC',
  });
}

function statusLabel(status: 'live' | 'playable' | 'snapshot-pending'): string {
  if (status === 'live') return 'LIVE';
  if (status === 'playable') return 'PLAYABLE';
  return 'SNAPSHOT PENDING';
}
---

<Base
  title="Spiral Evolution Timeline"
  description="Every deployed visual aesthetic of the Sovereign Systems Spiral, browseable as a versioned timeline."
>
  <main class="timeline-page">
    <header class="timeline-hero">
      <p class="timeline-eyebrow">Internal · Client Review</p>
      <h1>Spiral Evolution Timeline</h1>
      <p class="timeline-intro">
        Every deployed visual aesthetic of the Sovereign Systems Spiral,
        chronologically. Click any <strong>PLAYABLE</strong> entry to open the deployed
        version in a new tab. <strong>SNAPSHOT PENDING</strong> entries exist in git
        history but have not been re-deployed at their historical commit yet — they
        link to the source commit for now.
      </p>
      <p class="timeline-stats">
        <strong>{totalCount}</strong> versions ·
        <strong>{playableCount}</strong> playable ·
        <strong>{pendingCount}</strong> snapshot pending
      </p>
    </header>

    {
      live.length > 0 && (
        <section class="timeline-section section-live">
          <h2>Currently Live</h2>
          <p class="section-desc">
            What visitors see at{' '}
            <a
              href="https://sovereign-systems-spiral.pages.dev"
              target="_blank"
              rel="noopener"
            >
              sovereign-systems-spiral.pages.dev
            </a>{' '}
            right now. (Custom domain <code>elevatealign.com</code> is not yet
            pointed.)
          </p>
          <div class="version-grid">
            {live.map((v) => (
              <article class={`version-card status-${v.status}`}>
                <header class="card-header">
                  <h3>{v.name}</h3>
                  <span class="status-badge">{statusLabel(v.status)}</span>
                </header>
                <p class="card-date">{formatDate(v.date)}</p>
                <p class="card-desc">{v.description}</p>
                {v.notes && <p class="card-notes">{v.notes}</p>}
                <div class="card-actions">
                  {v.iframeSrc && (
                    <a
                      class="btn-open"
                      href={v.iframeSrc}
                      target="_blank"
                      rel="noopener"
                    >
                      Open ▸
                    </a>
                  )}
                </div>
              </article>
            ))}
          </div>
        </section>
      )
    }

    {
      historical.length > 0 && (
        <section class="timeline-section section-historical">
          <h2>V1 – V8 · Production History</h2>
          <p class="section-desc">
            The spiral's evolution from V1 (Apr 23) through V8 (Apr 26). Every
            version below has been re-deployed at its historical commit to a
            permanent{' '}
            <code>&lt;hash&gt;.sovereign-systems-spiral.pages.dev</code>
            URL — click any <strong>Open</strong> button to interact with the
            version exactly as it shipped on that date.
          </p>
          <div class="version-grid">
            {historical.map((v) => (
              <article class={`version-card status-${v.status}`}>
                <header class="card-header">
                  <h3>{v.name}</h3>
                  <span class="status-badge">{statusLabel(v.status)}</span>
                </header>
                <p class="card-date">{formatDate(v.date)}</p>
                <p class="card-desc">{v.description}</p>
                {v.notes && <p class="card-notes">{v.notes}</p>}
                <div class="card-actions">
                  {v.iframeSrc && (
                    <a
                      class="btn-open"
                      href={v.iframeSrc}
                      target="_blank"
                      rel="noopener"
                    >
                      Open ▸
                    </a>
                  )}
                  {v.commit && (
                    <a
                      class="btn-source"
                      href={`https://github.com/organvm-iii-ergon/sovereign-systems--elevate-align/commit/${v.commit}`}
                      target="_blank"
                      rel="noopener"
                    >
                      Source · <code>{v.commit}</code>
                    </a>
                  )}
                </div>
              </article>
            ))}
          </div>
        </section>
      )
    }

    <footer class="timeline-footer">
      <p>
        Internal lab experiments (Confluence × Apophatic batch, etc.) are
        <strong>not</strong> shown here — they live in <code
          >docs/spiral-experiments/</code
        >
        and are studio-internal reference, not site versions.
      </p>
    </footer>
  </main>
</Base>

<style>
  .timeline-page {
    max-width: 1100px;
    margin: 0 auto;
    padding: 3rem 1.5rem 6rem;
    color: var(--color-text, #e8e6e1);
  }

  .timeline-hero {
    text-align: center;
    margin-bottom: 4rem;
  }

  .timeline-eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    opacity: 0.6;
    margin-bottom: 0.5rem;
  }

  .timeline-hero h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    margin: 0 0 1rem;
    font-weight: 300;
    letter-spacing: -0.02em;
  }

  .timeline-intro {
    max-width: 640px;
    margin: 0 auto 1.5rem;
    font-size: 1.05rem;
    line-height: 1.6;
    opacity: 0.85;
  }

  .timeline-stats {
    font-size: 0.875rem;
    opacity: 0.7;
  }
  .timeline-stats strong {
    color: var(--color-accent, #c4a878);
    font-weight: 500;
  }

  .timeline-section {
    margin-bottom: 4rem;
  }

  .timeline-section h2 {
    font-size: 1.5rem;
    font-weight: 400;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    padding-bottom: 0.75rem;
    margin-bottom: 1rem;
  }

  .section-desc {
    margin: 0 0 2rem;
    font-size: 0.95rem;
    line-height: 1.55;
    opacity: 0.75;
    max-width: 720px;
  }

  .section-desc a {
    color: var(--color-accent, #c4a878);
    text-decoration: none;
    border-bottom: 1px solid currentColor;
  }

  .section-desc code,
  .timeline-footer code {
    font-family: ui-monospace, 'SF Mono', monospace;
    background: rgba(255, 255, 255, 0.05);
    padding: 0.15em 0.4em;
    border-radius: 3px;
    font-size: 0.9em;
  }

  .version-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.25rem;
  }

  .version-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    transition:
      border-color 0.2s ease,
      background 0.2s ease;
  }

  .version-card:hover {
    border-color: rgba(196, 168, 120, 0.4);
    background: rgba(255, 255, 255, 0.05);
  }

  .version-card.status-live {
    border-color: rgba(196, 168, 120, 0.5);
    background: rgba(196, 168, 120, 0.05);
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.75rem;
    margin-bottom: 0.25rem;
  }

  .card-header h3 {
    font-size: 1.05rem;
    font-weight: 500;
    margin: 0;
    line-height: 1.3;
    letter-spacing: -0.01em;
  }

  .status-badge {
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.08);
    white-space: nowrap;
    font-weight: 600;
  }

  .status-live .status-badge {
    background: var(--color-accent, #c4a878);
    color: #1a1a1a;
  }

  .status-playable .status-badge {
    background: rgba(120, 196, 168, 0.2);
    color: #78c4a8;
  }

  .status-snapshot-pending .status-badge {
    background: rgba(255, 255, 255, 0.05);
    color: rgba(255, 255, 255, 0.5);
  }

  .card-date {
    font-size: 0.8rem;
    opacity: 0.55;
    margin: 0 0 0.75rem;
  }

  .card-desc {
    margin: 0 0 0.75rem;
    font-size: 0.9rem;
    line-height: 1.5;
    opacity: 0.85;
    flex: 1;
  }

  .card-notes {
    font-size: 0.85rem;
    line-height: 1.5;
    opacity: 0.7;
    font-style: italic;
    margin: 0 0 0.75rem;
    padding: 0.5rem 0.75rem;
    background: rgba(255, 255, 255, 0.03);
    border-left: 2px solid rgba(196, 168, 120, 0.4);
    border-radius: 0 4px 4px 0;
  }

  .card-actions {
    margin-top: 1rem;
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .btn-open,
  .btn-source {
    display: inline-block;
    padding: 0.5rem 1rem;
    font-size: 0.85rem;
    border-radius: 6px;
    text-decoration: none;
    transition:
      background 0.15s ease,
      transform 0.1s ease;
  }

  .btn-open {
    background: var(--color-accent, #c4a878);
    color: #1a1a1a;
    font-weight: 600;
  }

  .btn-open:hover {
    background: #d4b888;
    transform: translateY(-1px);
  }

  .btn-source {
    background: rgba(255, 255, 255, 0.05);
    color: rgba(255, 255, 255, 0.7);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .btn-source code {
    font-family: ui-monospace, 'SF Mono', monospace;
    font-size: 0.8em;
    opacity: 0.7;
  }

  .btn-source:hover {
    background: rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.9);
  }

  .timeline-footer {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    font-size: 0.8rem;
    line-height: 1.6;
    opacity: 0.55;
  }

  @media (max-width: 640px) {
    .timeline-page {
      padding: 2rem 1rem 4rem;
    }
    .version-grid {
      grid-template-columns: 1fr;
    }
    .card-header {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
