---
import Base from '../layouts/Base.astro';
import {
  VOCABULARY,
  vocabularyByCategory,
  CATEGORY_LABEL,
  CATEGORY_DESCRIPTION,
  type VocabularyCategory,
} from '../data/aesthetics-vocabulary';
import { config, ui } from '../data/hub.config';
import type { EnvVar, Phase } from '../data/hub.config';
import { ICON_WORLDS, worldFor, hexToCss } from '../data/icon-worlds';
import { PRIMITIVES, ALL_ENV_VARS, PHI } from '../data/sacred-geometry-primitives';
import { LENS_MODULATION } from '../data/lens-geometry';
import {
  LENSES_IN_DISPLAY_ORDER,
  viewThroughLens,
  type Lens,
} from '../data/naming-chains';

const vocab = vocabularyByCategory();
const nodes = config.nodes;
const pillars = config.pillars;

const VESSEL_MODES = [
  {
    mode: 'invisible',
    label: 'Invisible',
    desc: 'Mesh hidden — only the particle field is visible. Most minimal; the node reads as a glowing cloud.',
  },
  {
    mode: 'visible',
    label: 'Visible (solid mesh)',
    desc: 'Opaque solid mesh, particle field suppressed. Most defined; the node reads as a sculpted object.',
  },
  {
    mode: 'refracted-star',
    label: 'Refracted Star',
    desc: 'Prismatic glass-like material with light transmission and dispersion. Most jewel-like.',
  },
  {
    mode: 'hybrid',
    label: 'Hybrid (current default)',
    desc: 'Solid mesh plus 30% particle field on top. Layered — both the form and the field, together.',
  },
] as const;

const NAV_VARIANTS = [
  {
    variant: 'pillar-first',
    label: 'Pillar-First (current default)',
    desc: 'Nav links to the four pillar pages — emphasizes the four-pillar framework.',
  },
  {
    variant: 'spiral-first',
    label: 'Spiral-First',
    desc: 'Nav links direct to nodes 1–13 in sequence — emphasizes the sequential journey.',
  },
] as const;

const LENS_DESCRIPTIONS: Record<Lens, string> = {
  'egyptian': 'Ancient, cosmic, hieroglyphic. Names anchored in solar theology and funerary tradition.',
  'sanskrit-vedic': 'Mandala, chakra, unfolding. Names anchored in Vedic and tantric tradition.',
  'greek-classical': 'Proportion, columnar, mathematical. Names anchored in geometry and natural philosophy.',
  'christian-mystical': 'Sacred heart, redemption, transformation. Names anchored in mystical theology.',
  'jungian': 'Archetype, collective unconscious. Names anchored in depth psychology.',
  'physics-elemental': 'Matter, energy, force. Names anchored in observed physical phenomena.',
  'modern-wellness': "Accessible, current, sovereign-systems-spiral specific. Maddie's naming layer.",
};

const LENS_PRETTY: Record<Lens, string> = {
  'egyptian': 'Egyptian',
  'sanskrit-vedic': 'Sanskrit-Vedic',
  'greek-classical': 'Greek-Classical',
  'christian-mystical': 'Christian-Mystical',
  'jungian': 'Jungian',
  'physics-elemental': 'Physics-Elemental',
  'modern-wellness': 'Modern-Wellness',
};

interface PhaseRow {
  phase: Phase;
  desc: string;
  nodes: typeof nodes;
}

const PHASES: PhaseRow[] = [
  {
    phase: 'ELEVATE',
    desc: 'Raise from baseline — bodily foundation, awareness, regulation. The Physical Sovereignty arc.',
    nodes: nodes.filter((n) => n.phase === 'ELEVATE'),
  },
  {
    phase: 'ALIGN',
    desc: 'Integrate mind and life — responsibility, release, clarity, becoming, awakening. Inner + Identity Sovereignty.',
    nodes: nodes.filter((n) => n.phase === 'ALIGN'),
  },
  {
    phase: 'UNLOCK',
    desc: 'Freedom and full flow — integration, authentic expression, gifts amplified. Identity + Financial Sovereignty.',
    nodes: nodes.filter((n) => n.phase === 'UNLOCK'),
  },
];

const CATEGORIES_IN_ORDER: VocabularyCategory[] = ['structure', 'visual', 'language', 'physics'];
---

<Base
  title="Aesthetic Manifest"
  description="The shared vocabulary, settings, and visual qualities of the Sovereign Systems Spiral — a client+studio reference."
>
  <main class="aesthetics-page">
    <header class="hero">
      <p class="eyebrow">Internal · Client + Studio</p>
      <h1>Aesthetic Manifest</h1>
      <p class="intro">
        Every named visual, structural, and linguistic quality of the Sovereign
        Systems Spiral. This page exists so that <strong>Maddie</strong> (client)
        and <strong>4jp + the studio</strong> share one vocabulary when talking
        about specific parts of the site — and so we can change live settings
        without redeploying.
      </p>
      <p class="intro-secondary">
        Each term has a <em>public name</em> (what we use in conversation) and
        a <em>technical name</em> in parentheses (the codebase identifier).
        Pick whichever lands.
      </p>
    </header>

    <nav class="toc" aria-label="Page sections">
      <h2>On this page</h2>
      <ol>
        <li><a href="#vocabulary">Vocabulary</a> — shared terms by category</li>
        <li><a href="#vessel-modes">Vessel Modes</a> — 4 live spiral renderings</li>
        <li><a href="#nav-variants">Nav Variants</a> — 2 navigation surfaces</li>
        <li><a href="#substrates">The 13 Substrates</a> — True Names of each node</li>
        <li><a href="#lenses">The 7 Lenses</a> — interpretive traditions</li>
        <li><a href="#pillars">The 4 Pillars</a> — content categories</li>
        <li><a href="#phases">The 3 Phases</a> — ELEVATE · ALIGN · UNLOCK</li>
        <li><a href="#chakra-spectrum">Chakra Spectrum</a> — 13-step color map</li>
        <li><a href="#geometry">Sacred Geometry Primitives</a> — math foundation</li>
        <li><a href="#worlds">Themed Worlds</a> — each node's environment</li>
      </ol>
    </nav>

    {/* ========================= VOCABULARY ========================= */}
    <section id="vocabulary" class="section">
      <h2>Vocabulary</h2>
      <p class="section-desc">
        Named primitives organized by category. Cite by public name in plain
        conversation; cite by technical name when pointing at code.
      </p>

      {CATEGORIES_IN_ORDER.map((cat) => (
        <div class="vocab-category">
          <h3 class="vocab-cat-header">
            <span class={`vocab-cat-badge cat-${cat}`}>{CATEGORY_LABEL[cat]}</span>
            <span class="vocab-cat-desc">{CATEGORY_DESCRIPTION[cat]}</span>
          </h3>
          <div class="vocab-grid">
            {vocab[cat].map((term) => (
              <article class="vocab-card">
                <header class="vocab-card-header">
                  <h4>{term.publicName}</h4>
                  {term.technicalName && (
                    <span class="tech-name">
                      <code>{term.technicalName}</code>
                    </span>
                  )}
                </header>
                <p class="vocab-def">{term.definition}</p>
                {term.example && (
                  <p class="vocab-example">
                    <span class="example-tag">Example.</span> {term.example}
                  </p>
                )}
                {term.link && (
                  <p class="vocab-link">
                    <a href={term.link} target="_blank" rel="noopener">
                      {term.linkLabel || 'Open →'}
                    </a>
                  </p>
                )}
              </article>
            ))}
          </div>
        </div>
      ))}
    </section>

    {/* ========================= VESSEL MODES ========================= */}
    <section id="vessel-modes" class="section">
      <h2>Vessel Modes</h2>
      <p class="section-desc">
        How each spiral node renders its substrate. The current default is
        <strong>{ui.spiralVesselMode}</strong>; you can preview any other mode
        live (no redeploy) by appending <code>?vessel=&lt;mode&gt;</code> to any
        page URL. The querystring takes precedence client-side.
      </p>
      <div class="mode-grid">
        {VESSEL_MODES.map((m) => (
          <article class={`mode-card ${ui.spiralVesselMode === m.mode ? 'is-current' : ''}`}>
            <header class="mode-header">
              <h3>{m.label}</h3>
              <code class="mode-key">?vessel={m.mode}</code>
            </header>
            <p class="mode-desc">{m.desc}</p>
            <div class="mode-actions">
              <a class="btn-preview" href={`/?vessel=${m.mode}`} target="_blank" rel="noopener">
                Preview ▸
              </a>
            </div>
          </article>
        ))}
      </div>
    </section>

    {/* ========================= NAV VARIANTS ========================= */}
    <section id="nav-variants" class="section">
      <h2>Nav Variants</h2>
      <p class="section-desc">
        Which way the top-of-page navigation points. Current default is
        <strong>{ui.navVariant}</strong>; preview the other variant with
        <code>?variant=&lt;variant&gt;</code> on any page URL.
      </p>
      <div class="mode-grid mode-grid--two">
        {NAV_VARIANTS.map((v) => (
          <article class={`mode-card ${ui.navVariant === v.variant ? 'is-current' : ''}`}>
            <header class="mode-header">
              <h3>{v.label}</h3>
              <code class="mode-key">?variant={v.variant}</code>
            </header>
            <p class="mode-desc">{v.desc}</p>
            <div class="mode-actions">
              <a class="btn-preview" href={`/?variant=${v.variant}`} target="_blank" rel="noopener">
                Preview ▸
              </a>
            </div>
          </article>
        ))}
      </div>
    </section>

    {/* ========================= THE 13 SUBSTRATES ========================= */}
    <section id="substrates" class="section">
      <h2>The 13 Substrates</h2>
      <p class="section-desc">
        Each spiral node has one immutable substrate identity (its
        <em> True Name</em>). The same essence has been recognized and re-named
        across many traditions for thousands of years; the substrate is the
        identity beneath all those names. Click any card to see that
        substrate's full chronological lineage.
      </p>
      <div class="substrate-grid">
        {nodes.map((n) => (
          <a class="substrate-card" href={`/lineage/${n.envVar}`} style={`--card-accent: ${n.color}`}>
            <header class="substrate-header">
              <span class="substrate-id">#{n.id}</span>
              <span class="substrate-glyph" aria-hidden="true">{n.emoji}</span>
            </header>
            <h3 class="substrate-name">{n.name}</h3>
            <p class="substrate-true-name">
              <code>{n.envVar}</code>
              <span class="substrate-chakra">{n.chakra || '—'}</span>
            </p>
            <p class="substrate-tagline">{n.tagline}</p>
            <p class="substrate-meta">
              <span>{n.phase}</span> · <span>{n.pillarSlug}</span>
            </p>
          </a>
        ))}
      </div>
    </section>

    {/* ========================= THE 7 LENSES ========================= */}
    <section id="lenses" class="section">
      <h2>The 7 Lenses</h2>
      <p class="section-desc">
        Seven interpretive traditions through which a substrate is named. The
        lens determines which name appears for a given essence — and each lens
        also <em>modulates</em> the generative geometry (vertex count, scale,
        twist) of the spiral node it renders.
      </p>
      <div class="lens-grid">
        {LENSES_IN_DISPLAY_ORDER.map((lens) => {
          const mod = LENS_MODULATION[lens];
          const examples = viewThroughLens(lens).slice(0, 3);
          return (
            <article class="lens-card">
              <header class="lens-header">
                <h3>{LENS_PRETTY[lens]}</h3>
                <code>{lens}</code>
              </header>
              <p class="lens-desc">{LENS_DESCRIPTIONS[lens]}</p>
              <dl class="lens-mod">
                <dt>Vertices added</dt><dd>{mod.vertexAddend > 0 ? `+${mod.vertexAddend}` : mod.vertexAddend}</dd>
                <dt>Scale ×</dt><dd>{mod.scaleMul}</dd>
                <dt>Twist Δ</dt><dd>{mod.twistAdd > 0 ? `+${mod.twistAdd}` : mod.twistAdd}</dd>
                <dt>Depth ×</dt><dd>{mod.depthMul}</dd>
                {mod.fractalDepth > 0 && (<><dt>Fractal depth</dt><dd>{mod.fractalDepth}</dd></>)}
                {mod.symmetryOverride && (<><dt>Symmetry override</dt><dd>{mod.symmetryOverride}</dd></>)}
              </dl>
              <p class="lens-examples">
                <span class="example-tag">Examples.</span>
                {examples.map((b, i) => (
                  <>
                    <em>{b.name}</em> ({b.envVar}){i < examples.length - 1 ? '; ' : '.'}
                  </>
                ))}
              </p>
            </article>
          );
        })}
      </div>
    </section>

    {/* ========================= THE 4 PILLARS ========================= */}
    <section id="pillars" class="section">
      <h2>The 4 Pillars</h2>
      <p class="section-desc">
        Content categories. Pillars are the topical organization (what kind of
        work this is); phases are the temporal arc (where in the journey).
      </p>
      <div class="pillar-grid">
        {pillars.map((p) => (
          <article class="pillar-card" style={`--card-accent: ${p.color}`}>
            <header class="pillar-header">
              <span class="pillar-emoji" aria-hidden="true">{p.emoji}</span>
              <span class="pillar-order">#{p.order}</span>
            </header>
            <h3>{p.name}</h3>
            <p class="pillar-tagline">{p.tagline}</p>
            <p class="pillar-meta">
              <code>{p.slug}</code> · <span class="status-{p.status}">{p.status}</span>
            </p>
            <p class="pillar-color">
              <span class="color-swatch" style={`background:${p.color}`} aria-hidden="true"></span>
              <code>{p.color}</code>
            </p>
            <p class="pillar-url">
              <a href={p.url}>{p.url} →</a>
            </p>
          </article>
        ))}
      </div>
    </section>

    {/* ========================= THE 3 PHASES ========================= */}
    <section id="phases" class="section">
      <h2>The 3 Phases</h2>
      <p class="section-desc">
        Stages of the journey arc. Where a user lands in the spiral depends on
        which phase they're in and which pillar they need work in.
      </p>
      {PHASES.map((p) => (
        <div class="phase-band">
          <h3>{p.phase}</h3>
          <p class="phase-desc">{p.desc}</p>
          <ul class="phase-nodes">
            {p.nodes.map((n) => (
              <li>
                <span class="phase-node-color" style={`background:${n.color}`} aria-hidden="true"></span>
                <a href={n.url}><strong>#{n.id}</strong> {n.name}</a>
                <span class="phase-node-meta">— {n.tagline}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </section>

    {/* ========================= CHAKRA SPECTRUM ========================= */}
    <section id="chakra-spectrum" class="section">
      <h2>Chakra Spectrum</h2>
      <p class="section-desc">
        The thirteen-step color map applied bottom-to-top across the spiral.
        Root (red, node 1) through crown (violet, node 13). Used in
        <code> spiral.ts</code> via <code>chakraColorForNode</code>.
      </p>
      <ol class="chakra-strip">
        {nodes.map((n) => (
          <li class="chakra-step" style={`--swatch:${n.color}`}>
            <span class="chakra-swatch" aria-hidden="true"></span>
            <span class="chakra-num">#{n.id}</span>
            <span class="chakra-label">{n.chakra || '—'}</span>
            <code class="chakra-hex">{n.color}</code>
          </li>
        ))}
      </ol>
    </section>

    {/* ========================= SACRED GEOMETRY ========================= */}
    <section id="geometry" class="section">
      <h2>Sacred Geometry Primitives</h2>
      <p class="section-desc">
        The mathematical foundation per substrate. Not "what should it look
        like" but "what mathematical law generates it." Golden ratio
        (φ = {PHI.toFixed(6)}) governs scale; vertex count is prime-constrained;
        symmetry is the governing law.
      </p>
      <div class="geo-table-wrap">
        <table class="geo-table">
          <thead>
            <tr>
              <th>#</th>
              <th>Substrate</th>
              <th>Vertices</th>
              <th>Symmetry</th>
              <th>PHI<sup>k</sup></th>
              <th>Inner ratio</th>
              <th>Twist</th>
              <th>Void?</th>
              <th>Depth</th>
            </tr>
          </thead>
          <tbody>
            {ALL_ENV_VARS.map((env, i) => {
              const p = PRIMITIVES[env];
              return (
                <tr>
                  <td>{i + 1}</td>
                  <td><code>{env}</code></td>
                  <td>{p.vertexCount}</td>
                  <td>{p.symmetry}</td>
                  <td>{p.phiExponent}</td>
                  <td>{p.innerRatio}</td>
                  <td>{p.twistFactor}</td>
                  <td>{p.hasCentralVoid ? '✓' : '—'}</td>
                  <td>{p.depthRatio}</td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </section>

    {/* ========================= THEMED WORLDS ========================= */}
    <section id="worlds" class="section">
      <h2>Themed Worlds</h2>
      <p class="section-desc">
        Per-node environment: elements (fire, water, plasma…), phase mix,
        biology, gravity vector, particle behavior, accent palette. Every node
        is its own complete world — "Halloween Town, Tomorrowland, Crystal Vault."
      </p>
      <div class="world-grid">
        {Object.entries(ICON_WORLDS).map(([id, w]) => {
          const node = nodes.find((n) => n.id === Number(id));
          return (
            <article class="world-card" style={`--card-accent:${node?.color || '#888'}`}>
              <header class="world-header">
                <h3>#{id} · {w.themeName}</h3>
                {node && <span class="world-node-name">{node.name}</span>}
              </header>
              <dl class="world-meta">
                <dt>Elements</dt><dd>{w.elements.join(' · ')}</dd>
                <dt>Biology</dt><dd>{w.biology}</dd>
                <dt>Behavior</dt><dd>{w.particleBehavior}</dd>
                <dt>Phase mix</dt><dd>
                  gas {Math.round(w.phaseMix.gas * 100)}% ·
                  liq {Math.round(w.phaseMix.liquid * 100)}% ·
                  sol {Math.round(w.phaseMix.solid * 100)}% ·
                  plasma {Math.round(w.phaseMix.plasma * 100)}%
                </dd>
                <dt>Gravity</dt><dd>
                  x {w.gravity.x} · y {w.gravity.y} · z {w.gravity.z}
                </dd>
                <dt>Thermal ×</dt><dd>{w.thermalAmpMul}</dd>
                <dt>Size bias</dt><dd>{w.sizeBias}</dd>
              </dl>
              <div class="world-palette" aria-label="Accent palette">
                {w.accentPalette.map((c) => (
                  <span class="palette-swatch" style={`background:${hexToCss(c)}`} title={hexToCss(c)}></span>
                ))}
              </div>
            </article>
          );
        })}
      </div>
    </section>

    <footer class="aesthetics-footer">
      <h2>Editing this manifest</h2>
      <ul>
        <li>Add or change a vocabulary term → <code>src/data/aesthetics-vocabulary.ts</code></li>
        <li>Add a vessel mode or change the default → <code>src/data/hub.config.ts</code> (<code>VesselMode</code>, <code>ui.spiralVesselMode</code>)</li>
        <li>Change a node's substrate, chakra, theme tags, color → <code>src/data/hub.config.ts</code> (<code>config.nodes[]</code>)</li>
        <li>Add a lens or change its modulation → <code>src/data/lens-geometry.ts</code></li>
        <li>Add a tradition naming binding → <code>src/data/naming-chains.ts</code></li>
        <li>Change a substrate's mathematical primitive → <code>src/data/sacred-geometry-primitives.ts</code></li>
        <li>Change a themed world → <code>src/data/icon-worlds.ts</code></li>
      </ul>
      <p class="footer-note">
        This page renders directly from those source files — every edit there
        becomes visible here on the next deploy.
      </p>
    </footer>
  </main>
</Base>

<style>
  .aesthetics-page {
    max-width: 1180px;
    margin: 0 auto;
    padding: 3rem 1.5rem 6rem;
    color: var(--color-text, #e8e6e1);
    line-height: 1.55;
  }

  .hero {
    text-align: center;
    margin-bottom: 3rem;
  }
  .eyebrow {
    font-size: 0.7rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    opacity: 0.55;
    margin: 0 0 0.5rem;
  }
  .hero h1 {
    font-size: clamp(2rem, 5vw, 3.25rem);
    margin: 0 0 1.25rem;
    font-weight: 300;
    letter-spacing: -0.02em;
  }
  .intro, .intro-secondary {
    max-width: 680px;
    margin: 0 auto 0.75rem;
    font-size: 1.05rem;
    opacity: 0.88;
  }
  .intro-secondary {
    opacity: 0.65;
    font-size: 0.95rem;
  }

  .toc {
    margin: 0 auto 4rem;
    max-width: 720px;
    padding: 1.5rem 1.75rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.02);
  }
  .toc h2 {
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    opacity: 0.6;
    margin: 0 0 0.75rem;
    font-weight: 600;
  }
  .toc ol {
    columns: 2;
    column-gap: 2rem;
    padding-left: 1.25rem;
    margin: 0;
    font-size: 0.9rem;
  }
  .toc li { margin: 0 0 0.35rem; }
  .toc a {
    color: var(--color-accent, #c4a878);
    text-decoration: none;
    border-bottom: 1px dotted rgba(196, 168, 120, 0.3);
  }
  .toc a:hover { border-bottom-style: solid; }

  .section {
    margin: 0 0 4.5rem;
  }
  .section h2 {
    font-size: 1.5rem;
    font-weight: 400;
    margin: 0 0 0.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }
  .section-desc {
    margin: 0 0 2rem;
    max-width: 760px;
    font-size: 0.97rem;
    opacity: 0.78;
  }
  .section-desc code,
  .footer-note code,
  .aesthetics-footer code,
  .vocab-link code,
  .tech-name code,
  .vocab-def code,
  .vocab-example code,
  .mode-key,
  .substrate-true-name code,
  .pillar-meta code,
  .pillar-color code,
  .lens-header code,
  .chakra-hex,
  .geo-table code,
  .world-card code {
    font-family: ui-monospace, 'SF Mono', monospace;
    font-size: 0.86em;
    background: rgba(255, 255, 255, 0.06);
    padding: 0.1em 0.4em;
    border-radius: 3px;
  }

  /* ============ VOCABULARY ============ */
  .vocab-category { margin: 0 0 2.5rem; }
  .vocab-cat-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    font-size: 0.95rem;
    font-weight: 400;
    margin: 0 0 1rem;
  }
  .vocab-cat-badge {
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 0.25rem 0.65rem;
    border-radius: 4px;
    font-weight: 600;
  }
  .vocab-cat-badge.cat-structure   { background: rgba(196, 168, 120, 0.18); color: #c4a878; }
  .vocab-cat-badge.cat-visual      { background: rgba(120, 196, 168, 0.18); color: #78c4a8; }
  .vocab-cat-badge.cat-language    { background: rgba(168, 120, 196, 0.18); color: #c97ce8; }
  .vocab-cat-badge.cat-physics     { background: rgba(196, 120, 80, 0.18);  color: #ff9a3c; }
  .vocab-cat-desc { opacity: 0.65; font-size: 0.88rem; }

  .vocab-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1rem;
  }
  .vocab-card {
    background: rgba(255, 255, 255, 0.03);
