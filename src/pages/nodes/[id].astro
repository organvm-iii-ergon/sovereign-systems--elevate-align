---
import Base from '../../layouts/Base.astro';
import Hero from '../../components/Hero.astro';
import CTAButton from '../../components/CTAButton.astro';
import { config } from '../../data/hub.config';
import type { SpiralNode } from '../../data/hub.config';

export function getStaticPaths() {
  return config.nodes
    .filter((n) => n.url.startsWith('/nodes/'))
    .map((node) => ({
      params: { id: String(node.id) },
      props: { node },
    }));
}

interface Props {
  node: SpiralNode;
}

const { node } = Astro.props;
const pillar = config.pillars.find((p) => p.slug === node.pillarSlug);
const phaseLabel = `${node.phase.charAt(0)}${node.phase.slice(1).toLowerCase()} Phase`;
const isLive = node.status === 'live';

// Sequential navigation
const allNodes = config.nodes;
const currentIndex = allNodes.findIndex((n) => n.id === node.id);
const prevNode = currentIndex > 0 ? allNodes[currentIndex - 1] : null;
const nextNode = currentIndex < allNodes.length - 1 ? allNodes[currentIndex + 1] : null;
---

<Base title={`${node.name} — ${config.name}`} description={node.tagline}>
  <Hero heading={node.name} subtext={node.tagline} section={phaseLabel} />

  {isLive ? (
    <section class="py-20 px-6 bg-ocean-900">
      <div class="max-w-2xl mx-auto">
        {node.id === 1 && (
          <>
            <h2 class="font-heading text-[24px] font-light text-white mb-6">Start where you are</h2>
            <p class="text-white/45 text-[16px] font-light leading-[1.9] mb-6">
              You don't need to overhaul everything at once. The first step is the simplest: notice how you feel right now. Not how you think you should feel — how you actually feel.
            </p>
            <p class="text-white/35 text-[15px] font-light leading-[1.9]">
              This node is about permission. Permission to start from wherever you are, without needing to earn your way to better health. The spiral begins here.
            </p>
          </>
        )}
        {node.id === 2 && (
          <>
            <h2 class="font-heading text-[24px] font-light text-white mb-6">See where you actually are</h2>
            <p class="text-white/45 text-[16px] font-light leading-[1.9] mb-6">
              Before mindset, before identity, before income — there is the body. If your physical foundation is unstable, every other system compensates for it. Energy, focus, mood, relationships — they all run on what your body provides.
            </p>
            <p class="text-white/35 text-[15px] font-light leading-[1.9]">
              Awareness isn't about judgment. It's about honest assessment — mapping what your body is actually telling you so the work that follows is precise, not guesswork.
            </p>
          </>
        )}
        {node.id === 3 && (
          <>
            <h2 class="font-heading text-[24px] font-light text-white mb-6">Regulate before you optimize</h2>
            <p class="text-white/45 text-[16px] font-light leading-[1.9] mb-6">
              Most people jump straight to optimization — supplements, protocols, biohacks. But if the baseline isn't regulated, optimization is noise on top of chaos. Regulation means your nervous system isn't constantly in fight-or-flight, your sleep-wake cycle is consistent, and your body can actually absorb what you give it.
            </p>
          </>
        )}
        {node.id === 4 && (
          <>
            <h2 class="font-heading text-[24px] font-light text-white mb-6">Rise above the baseline</h2>
            <p class="text-white/45 text-[16px] font-light leading-[1.9] mb-6">
              Once you've regulated — once the chaos has quieted and the foundation is stable — you can start to build. Elevation isn't about pushing harder. It's about raising the floor so that your new normal is what your old peak used to be.
            </p>
            <p class="text-white/35 text-[15px] font-light leading-[1.9] mb-6">
              This is the shift from survival to sovereignty. Your body isn't fighting anymore — it's ready to grow.
            </p>
          </>
        )}
      </div>
    </section>
  ) : (
    <section class="py-20 px-6 bg-ocean-900">
      <div class="max-w-md mx-auto text-center">
        <div class="glass-card p-10" style="border-color: rgba(17,154,158,0.15);">
          <div class="w-10 h-px bg-ocean-500/30 mx-auto mb-6"></div>
          <p class="text-[48px] mb-4">{node.emoji}</p>
          <h2 class="font-heading text-[24px] font-light text-white mb-3">Coming Soon</h2>
          <p class="text-white/35 text-[15px] font-light leading-relaxed mb-8">
            This node is part of the {phaseLabel}. It will unlock as the spiral grows.
          </p>
          {pillar && (
            <CTAButton href={pillar.url} label={`Explore ${pillar.name}`} variant="secondary" />
          )}
        </div>
      </div>
    </section>
  )}

  <!-- Sequential navigation -->
  <section class="py-12 px-6 bg-ocean-900 border-t border-white/[0.04]">
    <div class="max-w-2xl mx-auto">
      <div class="flex items-center justify-between">
        {prevNode ? (
          <a href={prevNode.url} class="group flex items-center gap-2 text-white/30 hover:text-white/60 transition-colors">
            <span class="text-[18px] group-hover:-translate-x-1 transition-transform">&larr;</span>
            <div class="text-right">
              <span class="text-[10px] uppercase tracking-[0.15em] text-white/20 block">Previous</span>
              <span class="text-[14px]">{prevNode.emoji} {prevNode.name}</span>
            </div>
          </a>
        ) : <div />}
        <a href="/" class="text-[11px] uppercase tracking-[0.15em] text-white/20 hover:text-white/40 transition-colors">
          Spiral
        </a>
        {nextNode ? (
          <a href={nextNode.url} class="group flex items-center gap-2 text-white/30 hover:text-white/60 transition-colors">
            <div>
              <span class="text-[10px] uppercase tracking-[0.15em] text-white/20 block">Next</span>
              <span class="text-[14px]">{nextNode.emoji} {nextNode.name}</span>
            </div>
            <span class="text-[18px] group-hover:translate-x-1 transition-transform">&rarr;</span>
          </a>
        ) : <div />}
      </div>
    </div>
  </section>
</Base>
