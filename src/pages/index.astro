---
import Base from '../layouts/Base.astro';
import SpiralIsland from '../components/spiral/SpiralIsland.astro';
import SpiralFallback from '../components/spiral/SpiralFallback.astro';
import PillarCard from '../components/PillarCard.astro';
import CTAButton from '../components/CTAButton.astro';
import VideoEmbed from '../components/VideoEmbed.astro';
import { config } from '../data/hub.config';
---

<Base title={config.name}>
  <!-- Spiral Hero -->
  <section class="relative bg-ocean-900 overflow-hidden">
    <!-- Desktop: tagline overlays canvas -->
    <div class="hidden md:flex absolute inset-0 z-10 flex-col items-center justify-center text-center pointer-events-none">
      <h1 class="font-heading text-[clamp(42px,6vw,72px)] font-light text-white/90 leading-[1.08] tracking-tight" style="text-shadow: 0 0 60px rgba(17,154,158,0.15);">
        Sovereign Systems Spiral
      </h1>
      <p class="mt-4 text-[17px] font-light text-white/40 max-w-[480px] leading-relaxed">
        {config.tagline}
      </p>
    </div>
    <!-- Mobile: tagline in normal flow -->
    <div class="md:hidden px-6 pt-12 pb-6 text-center">
      <h1 class="font-heading text-[clamp(36px,8vw,56px)] font-light text-white leading-[1.1] tracking-tight">
        Sovereign Systems Spiral
      </h1>
      <p class="mt-4 text-[15px] font-light text-white/40 max-w-[400px] mx-auto leading-relaxed">
        {config.tagline}
      </p>
    </div>
    <SpiralIsland />
    <SpiralFallback />
  </section>

  <!-- Quiz CTA -->
  <section class="py-20 px-6 bg-ocean-900 text-center">
    <div class="max-w-xl mx-auto">
      <p class="text-[11px] font-medium tracking-[0.2em] uppercase text-ocean-500 mb-3">Start Here</p>
      <h2 class="font-heading text-[clamp(28px,4vw,44px)] font-light text-white mb-4">
        What are you here for?
      </h2>
      <p class="text-white/40 text-[15px] font-light max-w-[440px] mx-auto mb-10 leading-relaxed">
        Take the quiz to find your starting point on the spiral.
      </p>
      <CTAButton href="/quiz" label="Take the Quiz" />
    </div>
  </section>

  <!-- Divider -->
  <div class="divider-line"></div>

  <!-- Pillar Phases -->
  <section class="py-24 px-6 bg-ocean-900">
    <div class="max-w-[800px] mx-auto">
      <p class="text-center text-[11px] font-medium tracking-[0.2em] uppercase text-ocean-500 mb-3">The Journey</p>
      <h2 class="font-heading text-[clamp(32px,4vw,48px)] font-light text-white text-center mb-16">
        Four Phases of Sovereignty
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        {config.pillars.map((pillar) => (
          <PillarCard pillar={pillar} />
        ))}
      </div>
    </div>
  </section>

  <!-- Quote -->
  <section class="py-24 px-6 bg-ocean-900">
    <div class="max-w-[680px] mx-auto text-center">
      <div class="w-10 h-px bg-gold/40 mx-auto mb-12"></div>
      <blockquote class="font-heading text-[clamp(22px,3vw,32px)] font-light italic leading-[1.6] text-white/70">
        Most people try to fix their mindset while their foundation is unstable.
        Growth isn't linear. It's spiral. But it requires a backbone.
      </blockquote>
      <div class="w-10 h-px bg-gold/40 mx-auto mt-12"></div>
    </div>
  </section>

  <!-- Video — What is this? -->
  <section class="py-20 px-6 bg-ocean-900">
    <div class="max-w-3xl mx-auto">
      <p class="text-center text-[11px] font-medium tracking-[0.2em] uppercase text-ocean-500 mb-3">The Story</p>
      <h2 class="font-heading text-[clamp(24px,3vw,36px)] font-light text-white text-center mb-10">
        What is Sovereign Systems?
      </h2>
      <VideoEmbed placeholder={true} title="What is Sovereign Systems?" />
    </div>
  </section>

  <!-- CTA -->
  <section class="py-28 px-6 glow-bg text-center">
    <div class="relative max-w-xl mx-auto">
      <h2 class="font-heading text-[clamp(36px,5vw,56px)] font-light text-white mb-4" style="text-shadow: 0 0 60px rgba(17,154,158,0.12);">
        Start the spiral
      </h2>
      <p class="text-white/40 text-[16px] font-light max-w-[440px] mx-auto mb-10 leading-relaxed">
        Growth isn't linear. Find where you are and begin.
      </p>
      <CTAButton href="/quiz" label="Take the Quiz" />
    </div>
  </section>
</Base>
