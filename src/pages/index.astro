---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import SpiralIsland from '../components/spiral/SpiralIsland.astro';
import SpiralFallback from '../components/spiral/SpiralFallback.astro';
import PillarCard from '../components/PillarCard.astro';
import CTAButton from '../components/CTAButton.astro';
import { config } from '../data/hub.config';
---

<Base title={config.name}>
  <!-- 1. Hero -->
  <Hero heading={config.name} subtext={config.tagline} dark={true} />

  <!-- 2. Interactive spiral -->
  <section class="relative bg-ocean-900 overflow-hidden">
    <SpiralIsland />
    <SpiralFallback />
  </section>

  <!-- 3. Pillar cards -->
  <section class="py-20 px-6 bg-sand-50">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-heading text-4xl font-semibold text-text-primary text-center mb-12">
        The Four Pillars
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {config.pillars.map((pillar) => (
          <PillarCard pillar={pillar} />
        ))}
      </div>
    </div>
  </section>

  <!-- 4. Positioning quote -->
  <section class="py-20 px-6 bg-sand-100">
    <div class="max-w-3xl mx-auto">
      <blockquote class="text-center">
        <p class="font-heading text-2xl md:text-3xl font-semibold text-text-primary leading-relaxed italic">
          "Most people try to fix their mindset while their foundation is unstable. Growth isn't linear. It's spiral. But it requires a backbone."
        </p>
      </blockquote>
    </div>
  </section>

  <!-- 5. CTA section -->
  <section class="py-20 px-6 bg-ocean-900 text-center">
    <div class="max-w-xl mx-auto">
      <h2 class="font-heading text-4xl font-semibold text-text-on-dark mb-4">
        Start at the root
      </h2>
      <p class="text-ocean-200 text-lg leading-relaxed mb-8">
        Physical sovereignty is where everything begins. Stabilize the body first.
      </p>
      <CTAButton href="/water/" label="Begin with Water" variant="primary" />
    </div>
  </section>
</Base>
