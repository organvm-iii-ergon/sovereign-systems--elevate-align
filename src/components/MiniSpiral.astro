---
import { config } from '../data/hub.config';

const { branches } = config;
---

<div class="py-12 px-6 max-w-2xl mx-auto">
  <div class="text-center mb-10">
    <div class="text-4xl mb-3">🌊</div>
    <h2 class="font-heading text-[24px] font-light text-white">The Water Hub</h2>
  </div>

  <div class="grid grid-cols-2 gap-4">
    {branches.map((branch) => (
      <a
        href={`/water/${branch.slug}`}
        class="glass-card flex items-center gap-3 p-5 group"
      >
        <span class="text-2xl flex-shrink-0">{branch.emoji}</span>
        <span class="text-[14px] font-medium text-white/60 group-hover:text-white transition-colors">
          {branch.name}
        </span>
      </a>
    ))}
  </div>
</div>
