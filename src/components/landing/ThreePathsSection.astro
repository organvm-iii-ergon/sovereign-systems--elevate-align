---
import type { ThreePathsSectionProps } from '@/lib/landing-engine/sections';

interface Props {
  data: ThreePathsSectionProps;
}

const { data } = Astro.props;
---

<section class="relative px-6 py-24 max-w-[1080px] mx-auto">
  <h2
    class="font-heading text-[clamp(28px,3.5vw,44px)] font-light text-white leading-tight text-center"
  >
    {data.heading}
  </h2>
  <div class="mt-14 grid gap-6 md:grid-cols-3">
    {
      data.paths.map((path) => (
        <a
          href={path.href}
          class="group block p-8 rounded-2xl border border-white/10 bg-white/[0.02] hover:bg-white/[0.04] hover:border-ocean-500/40 transition-colors"
        >
          <p class="text-[11px] font-medium tracking-[0.2em] uppercase text-ocean-500 mb-3">
            {path.label}
          </p>
          <p class="text-[15px] font-light leading-relaxed text-white/55 group-hover:text-white/75 transition-colors">
            {path.description}
          </p>
        </a>
      ))
    }
  </div>
</section>
