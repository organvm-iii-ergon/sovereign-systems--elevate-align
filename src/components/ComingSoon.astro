---
interface Props {
  title: string;
  emoji: string;
  message?: string;
}

const { title, emoji, message = 'This branch is growing. Check back soon.' } = Astro.props;
---

<div class="py-20 px-6 text-center max-w-2xl mx-auto">
  <div class="text-6xl mb-6" aria-hidden="true">{emoji}</div>
  <h2 class="font-heading text-4xl font-semibold text-text-primary mb-4">{title}</h2>
  <p class="text-text-muted text-lg leading-relaxed">{message}</p>
</div>
