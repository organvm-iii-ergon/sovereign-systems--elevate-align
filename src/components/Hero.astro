---
interface Props {
  heading: string;
  subtext?: string;
  dark?: boolean;
}

const { heading, subtext, dark = false } = Astro.props;
---

<section
  class:list={[
    'relative py-24 md:py-32 px-6 overflow-hidden',
    dark ? 'section-glow text-white' : 'bg-sand-50',
  ]}
>
  {dark && (
    <div class="absolute inset-0 opacity-20" style="background: radial-gradient(ellipse at 30% 80%, rgba(61, 191, 196, 0.2), transparent 50%), radial-gradient(ellipse at 70% 20%, rgba(201, 169, 110, 0.15), transparent 50%);" />
  )}
  <div class="relative max-w-4xl mx-auto text-center">
    <h1
      class:list={[
        'font-heading text-5xl md:text-7xl font-normal leading-[1.1] tracking-tight',
        dark ? 'text-white text-glow' : 'text-text-primary',
      ]}
    >
      {heading}
    </h1>
    {subtext && (
      <p
        class:list={[
          'mt-6 text-lg md:text-xl leading-relaxed max-w-2xl mx-auto font-light',
          dark ? 'text-ocean-200' : 'text-text-body',
        ]}
      >
        {subtext}
      </p>
    )}
    <div class="mt-10 flex flex-wrap gap-4 justify-center">
      <slot />
    </div>
  </div>
</section>
