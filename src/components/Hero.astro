---
interface Props {
  heading: string;
  subtext?: string;
}

const { heading, subtext } = Astro.props;
---

<section class="relative min-h-[85vh] flex flex-col items-center justify-center text-center px-6 py-24 glow-bg overflow-hidden">
  <h1 class="relative font-heading text-[clamp(42px,6vw,80px)] font-light leading-[1.08] tracking-tight text-white" style="text-shadow: 0 0 60px rgba(17,154,158,0.15);">
    {heading}
  </h1>
  {subtext && (
    <p class="relative mt-6 text-[17px] font-light leading-relaxed text-white/45 max-w-[540px]">
      {subtext}
    </p>
  )}
  <div class="relative mt-10 flex flex-wrap gap-4 justify-center">
    <slot />
  </div>
</section>
