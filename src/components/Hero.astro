---
interface Props {
  heading: string;
  subtext?: string;
  dark?: boolean;
}

const { heading, subtext, dark = false } = Astro.props;
---

<section
  class:list={[
    'py-20 px-6',
    dark ? 'bg-ocean-900' : 'bg-sand-50',
  ]}
>
  <div class="max-w-4xl mx-auto text-center">
    <h1
      class:list={[
        'font-heading text-5xl md:text-6xl font-semibold leading-tight',
        dark ? 'text-text-on-dark' : 'text-text-primary',
      ]}
    >
      {heading}
    </h1>
    {subtext && (
      <p
        class:list={[
          'mt-6 text-lg md:text-xl leading-relaxed max-w-2xl mx-auto',
          dark ? 'text-ocean-200' : 'text-text-body',
        ]}
      >
        {subtext}
      </p>
    )}
    <div class="mt-8 flex flex-wrap gap-4 justify-center">
      <slot />
    </div>
  </div>
</section>
