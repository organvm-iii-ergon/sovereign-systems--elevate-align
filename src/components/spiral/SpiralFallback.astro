---
/**
 * SpiralFallback — Graceful degradation (no WebGL / no JS).
 *
 * Renders all 13 spiral nodes as a vertical card list grouped by phase.
 * Visible by default; hidden programmatically when 3D helix loads.
 */
import { config } from '../../data/hub.config';

const phaseConfig: Record<string, { label: string; color: string }> = {
  ELEVATE: { label: 'Elevate', color: '#119a9e' },
  ALIGN: { label: 'Align', color: '#8cc5d3' },
  UNLOCK: { label: 'Unlock', color: '#3dbfc4' },
};

type PhaseKey = keyof typeof phaseConfig;
const phases = Object.keys(phaseConfig) as PhaseKey[];

function nodesByPhase(phase: string) {
  return config.nodes.filter((n) => n.phase === phase);
}
---

<div id="spiral-fallback" class="px-4 py-8 space-y-6">
  {
    phases.map((phase) => {
      const pc = phaseConfig[phase];
      const nodes = nodesByPhase(phase);
      if (!nodes.length) return null;

      return (
        <div>
          <div class="flex items-center gap-2 mb-3 px-1">
            <div
              class="w-2 h-2 rounded-full"
              style={`background:${pc.color};`}
            />
            <span
              class="text-[10px] font-medium tracking-[0.15em] uppercase"
              style={`color:${pc.color};`}
            >
              {pc.label}
            </span>
            <div
              class="flex-1 h-px opacity-20"
              style={`background:${pc.color};`}
            />
          </div>
          <div class="space-y-2">
            {nodes.map((node) => {
              const isLive = node.status === 'live';
              const Tag = isLive ? 'a' : 'div';
              return (
                <Tag
                  href={isLive ? node.url : undefined}
                  class:list={[
                    'flex items-center gap-3 px-4 py-3 rounded-lg border transition-all',
                    isLive
                      ? 'border-white/10 bg-white/[0.03] hover:bg-white/[0.06] hover:border-white/20'
                      : 'border-white/5 bg-white/[0.01] opacity-40',
                  ]}
                  style={`border-left: 3px solid ${isLive ? node.color : 'rgba(255,255,255,0.1)'};`}
                >
                  <span class="text-xl flex-shrink-0">{node.emoji}</span>
                  <div class="flex-1 min-w-0">
                    <p class="text-sm font-medium text-white/80 truncate">
                      {node.name}
                    </p>
                    <p class="text-[11px] text-white/30 truncate">
                      {node.tagline}
                    </p>
                  </div>
                  {isLive ? (
                    <span class="text-white/20 text-xs flex-shrink-0">
                      &rsaquo;
                    </span>
                  ) : (
                    <span class="text-[9px] text-white/15 uppercase tracking-wider flex-shrink-0">
                      soon
                    </span>
                  )}
                </Tag>
              );
            })}
          </div>
        </div>
      );
    })
  }
</div>
