---
import { config } from '../../data/hub.config';

const { pillars } = config;
const delays = ['0s', '0.3s', '0.6s', '0.9s'];
---

<div class="md:hidden px-6 py-8 flex flex-col items-center gap-4">
  {pillars.map((pillar, i) => {
    const isLive = pillar.status === 'live';
    const Tag = isLive ? 'a' : 'div';
    return (
      <Tag
        href={isLive ? pillar.url : undefined}
        class:list={[
          'spiral-card glass-card w-full max-w-sm flex items-center gap-4 p-5',
          !isLive && 'opacity-40 hover:transform-none hover:shadow-none',
        ]}
        style={`animation-delay: ${delays[i]};`}
      >
        <span class="text-3xl flex-shrink-0">{pillar.emoji}</span>
        <div>
          <p class="font-medium text-white/80 text-sm">{pillar.name}</p>
          <p class="text-white/30 text-xs mt-0.5">{pillar.tagline}</p>
          {!isLive && (
            <p class="text-white/20 text-[10px] mt-1 uppercase tracking-wider">coming soon</p>
          )}
        </div>
      </Tag>
    );
  })}
</div>

<style>
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(-5px); }
  }
  .spiral-card {
    animation: float 3.5s ease-in-out infinite;
  }
</style>
