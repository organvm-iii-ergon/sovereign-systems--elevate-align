---
/**
 * SpiralIsland — Desktop Three.js helix wrapper.
 *
 * Dynamically imports spiral.ts (Three.js 3D helix renderer).
 * Node data is passed via data attribute on the container div.
 * Container is hidden below md breakpoint — mobile gets SpiralFallback.
 */
import { config } from '../../data/hub.config';

const nodesJson = JSON.stringify(config.nodes);
---

<div class="relative w-full hidden md:block h-[85vh]">
  <div
    id="spiral-container"
    class="absolute inset-0 w-full h-full"
    data-nodes={nodesJson}
  ></div>
</div>

<script>
  const INIT_KEY = '__spiralCleanup';

  function boot(): void {
    if (!window.matchMedia('(min-width: 768px)').matches) return;

    const container = document.getElementById('spiral-container');
    if (!container) return;

    // Kill any existing instance before starting a new one
    if ((window as any)[INIT_KEY]) {
      (window as any)[INIT_KEY]();
      (window as any)[INIT_KEY] = null;
    }

    const raw = container.dataset.nodes;
    if (!raw) return;

    import('./spiral.ts').then(({ initSpiral }) => {
      const nodes = JSON.parse(raw);
      const cleanup = initSpiral(container, nodes);

      (window as any)[INIT_KEY] = cleanup;

      // Cleanup on Astro view transition
      document.addEventListener('astro:before-swap', () => {
        cleanup();
        (window as any)[INIT_KEY] = null;
      }, { once: true });
    });
  }

  boot();
</script>
