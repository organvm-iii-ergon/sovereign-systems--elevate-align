---
/**
 * SpiralIsland — Desktop canvas wrapper.
 *
 * Uses a module <script> so Vite bundles the dynamic import of spiral.ts.
 * Pillar data is passed via a data attribute on the canvas element.
 * Canvas container is hidden below md breakpoint via Tailwind.
 */
import { config } from '../../data/hub.config';

const pillarsJson = JSON.stringify(config.pillars);
---

<div class="relative w-full hidden md:block h-[80vh]">
  <canvas
    id="spiral-canvas"
    class="absolute inset-0 w-full h-full"
    data-pillars={pillarsJson}
  ></canvas>
</div>

<script>
  // Guard against double-initialization (causes ghost echoes)
  const INIT_KEY = '__spiralCleanup';

  function boot(): void {
    if (!window.matchMedia('(min-width: 768px)').matches) return;

    const canvas = document.getElementById('spiral-canvas') as HTMLCanvasElement | null;
    if (!canvas) return;

    // Kill any existing animation loop before starting a new one
    if ((window as any)[INIT_KEY]) {
      (window as any)[INIT_KEY]();
      (window as any)[INIT_KEY] = null;
    }

    const raw = canvas.dataset.pillars;
    if (!raw) return;

    import('./spiral.ts').then(({ initSpiral }) => {
      const pillars = JSON.parse(raw);
      const cleanup = initSpiral(canvas, pillars);

      // Store cleanup so we can kill it if boot runs again
      (window as any)[INIT_KEY] = cleanup;

      // Cleanup on Astro view transition
      document.addEventListener('astro:before-swap', () => {
        cleanup();
        (window as any)[INIT_KEY] = null;
      }, { once: true });
    });
  }

  boot();
</script>
