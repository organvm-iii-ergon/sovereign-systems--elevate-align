---
interface Props {
  src?: string;
  title?: string;
  placeholder?: boolean;
}

const { src, title = 'Video', placeholder = false } = Astro.props;
const showPlaceholder = placeholder || !src;
---

<div
  class="w-full aspect-video rounded-2xl overflow-hidden relative"
  style="background: linear-gradient(135deg, #071e22 0%, #113d42 50%, #0c2e33 100%);"
>
  {
    showPlaceholder ? (
      <div class="absolute inset-0 flex flex-col items-center justify-center gap-5">
        <div class="w-20 h-20 rounded-full border border-ocean-500/20 flex items-center justify-center bg-white/[0.03] backdrop-blur-sm">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-7 h-7 text-ocean-400 ml-1"
            fill="currentColor"
            viewBox="0 0 24 24"
          >
            <path d="M8 5v14l11-7z" />
          </svg>
        </div>
        <div class="text-center px-6">
          <p class="text-white/45 text-[13px] font-light tracking-wider">
            {title}
          </p>
          <p class="text-white/20 text-[11px] font-light mt-2">
            Story slot reserved for the final client video asset.
          </p>
        </div>
      </div>
    ) : (
      <iframe
        src={src}
        title={title}
        class="w-full h-full border-0"
        allowfullscreen
        loading="lazy"
      />
    )
  }
</div>
