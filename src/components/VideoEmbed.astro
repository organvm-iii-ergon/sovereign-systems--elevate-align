---
interface Props {
  src?: string;
  title?: string;
  placeholder?: boolean;
}

const { src, title = 'Video', placeholder = false } = Astro.props;

const showPlaceholder = placeholder || !src;
---

<div class="w-full aspect-video rounded-lg overflow-hidden bg-ocean-900 relative">
  {showPlaceholder ? (
    <div class="absolute inset-0 flex flex-col items-center justify-center gap-4 text-text-on-dark">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="w-16 h-16 text-ocean-400"
        fill="currentColor"
        viewBox="0 0 24 24"
        aria-hidden="true"
      >
        <path d="M8 5v14l11-7z" />
      </svg>
      <p class="text-ocean-200 text-sm font-medium tracking-wide">Documentary coming soon</p>
    </div>
  ) : (
    <iframe
      src={src}
      title={title}
      class="w-full h-full border-0"
      allowfullscreen
      loading="lazy"
    />
  )}
</div>
