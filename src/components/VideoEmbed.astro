---
interface Props {
  src?: string;
  title?: string;
  placeholder?: boolean;
}

const { src, title = 'Video', placeholder = false } = Astro.props;
const showPlaceholder = placeholder || !src;
---

<div class="w-full aspect-video rounded-2xl overflow-hidden relative" style="background: linear-gradient(135deg, #0a2a2f 0%, #145050 50%, #0f3a40 100%);">
  {showPlaceholder ? (
    <div class="absolute inset-0 flex flex-col items-center justify-center gap-5">
      <div class="w-20 h-20 rounded-full border border-ocean-400/30 flex items-center justify-center bg-ocean-400/5 backdrop-blur-sm">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-8 h-8 text-ocean-400 ml-1"
          fill="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path d="M8 5v14l11-7z" />
        </svg>
      </div>
      <p class="text-ocean-300/60 text-sm font-light tracking-wider">Documentary coming soon</p>
    </div>
  ) : (
    <iframe
      src={src}
      title={title}
      class="w-full h-full border-0"
      allowfullscreen
      loading="lazy"
    />
  )}
</div>
