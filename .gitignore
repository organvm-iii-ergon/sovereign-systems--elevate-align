node_modules/
dist/
.astro/
.netlify/
.superpowers/
.DS_Store
# Ensure public/ assets are tracked (overrides global gitignore)
!public/
.wrangler/

output/
*.txt
# Track durable client-IP exports (e.g. ChatGPT conversation forwards from Maddie).
# These are durable artifacts that satisfy Universal Rule #2 (nothing local only);
# the broader *.txt ignore prevents accidental commits of ephemeral session logs.
!docs/maddie/chat-exports/*.txt

# IDE / editor caches
.vscode/
.history/
.lh/

# AI tooling caches (NOT .conductor/ — entry permits live there)
.gemini/
.specstory/

# Session export artifacts (ephemeral)
export-*.md
session-ses_*.md

# Debug heap dumps (regenerable; never committed)
*.heapsnapshot

# Cross-client IP isolation — local-only artifacts that touch
# multi-client showcases or pre-publication client docs.
# README is tracked so the convention is discoverable; everything else local-only.
.private/*
!.private/README.md
